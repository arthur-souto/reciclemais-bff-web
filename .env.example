PORT=3000

# Groq (IA usada na análise de evidências)
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3.6-27b
GROQ_VISION_MODEL=qwen/qwen3.6-27b

# Postgres (usado pelo docker-compose e pela aplicação)
POSTGRES_DB=recicle_db
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev

# String de conexão usada pela aplicação e pelo drizzle-kit
DATABASE_URL=postgresql://dev:dev@localhost:5432/recicle_db

# JWT (usado para autenticação)
JWT_SECRET=
JWT_EXPIRES_IN=1d
